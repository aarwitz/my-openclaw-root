{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "raw_case.schema.json",
  "title": "RawValidationCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "case_class",
    "fake_date_variant",
    "raw_world_change",
    "sector_or_theme",
    "structural_features",
    "primary_source_class",
    "model_decision_json",
    "resolved_outcome_json",
    "created_at",
    "experiment_id"
  ],
  "properties": {
    "id": { "type": "string" },
    "case_class": { "type": "string", "enum": ["winner", "negative_control", "post_cutoff"] },
    "fake_date_variant": { "type": ["string", "null"] },
    "raw_world_change": { "type": "string", "minLength": 20 },
    "masked_world_change_override": { "type": "string" },
    "sector_or_theme": { "type": "string", "minLength": 3 },
    "structural_features": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 3 }
    },
    "primary_source_class": { "type": "string", "minLength": 3 },
    "entities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "companies": { "type": "array", "items": { "type": "string" } },
        "tickers": { "type": "array", "items": { "type": "string" } },
        "people": { "type": "array", "items": { "type": "string" } },
        "deals": { "type": "array", "items": { "type": "string" } }
      }
    },
    "model_decision_json": { "type": "object" },
    "resolved_outcome_json": { "type": "object" },
    "passed": { "type": "integer", "enum": [0, 1], "default": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "experiment_id": { "type": "string", "minLength": 3 }
  }
}
